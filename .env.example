# Ejemplo de .env para pruebas locales
# Copia este archivo a `.env` y rellena las variables.

# Opción 1: URL completa (recomendada)
# DATABASE_URL="mssql+pymssql://USER:PASSWORD@del-campo-al-algoritmo.mssql.somee.com:1433/del-campo-al-algoritmo"

# Opción 2: variables separadas (el script las combina automáticamente)
# MSSQL_USER=tu_usuario
# MSSQL_PASS=tu_contraseña
# MSSQL_HOST=del-campo-al-algoritmo.mssql.somee.com
# MSSQL_DB=del-campo-al-algoritmo

# Clave para Flask (no dejes esto en producción)
# SECRET_KEY=clave_de_prueba

# Si quieres crear un admin automáticamente al arrancar
# DEFAULT_ADMIN_PASSWORD=tu_password_admin
